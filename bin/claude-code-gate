#!/usr/bin/env python3
"""HookBus thin client for Claude Code hooks.

Reads the hook JSON Claude Code writes to stdin, posts it to the HookBus HTTP
endpoint, and translates the bus verdict back into Claude Code's per-event
output schema.

Supported hook events:
    UserPromptSubmit  , plain text injection (additionalContext)
    PreToolUse        , hookSpecificOutput.permissionDecision + reason
    PostToolUse       , hookSpecificOutput.additionalContext (optional)
    Stop              , top-level decision / reason (schema forbids hookSpecificOutput)

Environment:
    HOOKBUS_URL       default http://localhost:18800/event
    HOOKBUS_TOKEN     bearer token, optional
    HOOKBUS_SOURCE    label for dashboard, default claude-code
    HOOKBUS_TIMEOUT   HTTP timeout in seconds, default 30
    HOOKBUS_FAIL_MODE 'open' (default) allows on bus unreachable; 'closed' denies
    HOOKBUS_DEBUG     set to '1' to emit diagnostic logs on stderr

Exit codes:
    0 allow (Claude Code continues)
    2 deny  (Claude Code blocks the action)

On bus unreachable the gate fails open by default (HOOKBUS_FAIL_MODE=open) so
Claude Code is never bricked by a missing bus. Set HOOKBUS_FAIL_MODE=closed for
regulated environments that require governance to be enforced even when the bus
is down.

Licence: MIT. Copyright 2026 Agentic Thinking Limited.
"""
import json
import os
import shlex
import sys
import uuid
import urllib.request
from datetime import datetime, timezone
from pathlib import Path
from urllib.parse import urlparse


__version__ = "0.2.2"


def _load_local_hookbus_env():
    if os.environ.get("HOOKBUS_TOKEN"):
        return
    env_path = Path.home() / "hookbus-light" / ".env"
    if not env_path.exists():
        return
    try:
        for line in env_path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            key = key.strip()
            value = value.strip().strip('"').strip("'")
            if key.startswith("HOOKBUS_") and key not in os.environ:
                os.environ[key] = value
    except Exception:
        return


_load_local_hookbus_env()

BUS_URL = os.environ.get("HOOKBUS_URL", "http://localhost:18800/event")
TOKEN = os.environ.get("HOOKBUS_TOKEN", "").strip()
def _detect_source():
    # Auto-detect the invoking CLI to correctly label events on shared hosts.
    # Cursor CLI sets CURSOR_INVOKED_AS; if present we were called by cursor,
    # not by Claude Code, and the bus label must reflect that so dashboards
    # dont attribute another CLIs activity to claude-code.
    #
    # Explicit override via HOOKBUS_SOURCE env always wins (lets users force
    # a label in test harnesses or exotic setups).
    override = os.environ.get("HOOKBUS_SOURCE")
    if override:
        return override
    if os.environ.get("CURSOR_INVOKED_AS"):
        return "cursor-cli"
    if os.environ.get("AMP_INVOKED_AS"):
        return "amp"
    return "claude-code"


SOURCE = _detect_source()
TIMEOUT = int(os.environ.get("HOOKBUS_TIMEOUT", "30"))
_FAIL_MODE_RAW = os.environ.get("HOOKBUS_FAIL_MODE", "open").strip().lower()
FAIL_MODE = "closed" if _FAIL_MODE_RAW == "closed" else "open"
DEBUG = os.environ.get("HOOKBUS_DEBUG", "") == "1"
PUBLISHER_ID = os.environ.get(
    "HOOKBUS_PUBLISHER_ID",
    "uk.agenticthinking.publisher.anthropic.claude-code",
).strip()


def _log(level, msg):
    if not DEBUG and level == "info":
        return
    sys.stderr.write("[hookbus-claude-code] {}: {}\n".format(level, msg))


# Startup validation: warn on obviously-broken config but do not crash.
try:
    _parsed_url = urlparse(BUS_URL)
    if _parsed_url.scheme not in ("http", "https"):
        _log("error", "HOOKBUS_URL has unsupported scheme '{}', only http/https allowed".format(_parsed_url.scheme))
    elif not _parsed_url.netloc:
        _log("error", "HOOKBUS_URL missing host: {}".format(BUS_URL))
except Exception as _e:
    _log("error", "HOOKBUS_URL is not a valid URL ({}): {}".format(BUS_URL, _e))
if not TOKEN:
    _log("warn", "HOOKBUS_TOKEN is empty; authenticated buses will reject requests")
_log("info", "started v{} (source={}, fail_mode={}, bus={})".format(__version__, SOURCE, FAIL_MODE, BUS_URL))


def _read_hook_input():
    raw = sys.stdin.read()
    if not raw.strip():
        return None
    try:
        return json.loads(raw)
    except Exception as e:
        _log("warn", "hook stdin is not valid JSON: {}".format(e))
        return None


def _identity_metadata():
    fields = {
        "publisher_id": PUBLISHER_ID,
        "user_id": os.environ.get("HOOKBUS_USER_ID", "").strip(),
        "account_id": os.environ.get("HOOKBUS_ACCOUNT_ID", "").strip(),
        "instance_id": os.environ.get("HOOKBUS_INSTANCE_ID", "").strip(),
        "host_id": os.environ.get("HOOKBUS_HOST_ID", "").strip(),
    }
    return {key: value for key, value in fields.items() if value}


def _post_event_to(envelope, bus_url=BUS_URL, token=TOKEN):
    try:
        body = json.dumps(envelope).encode()
    except (TypeError, ValueError) as e:
        _log("warn", "envelope serialisation failed: {}".format(e))
        return None

    headers = {"Content-Type": "application/json"}
    if token:
        headers["Authorization"] = "Bearer " + token
    req = urllib.request.Request(bus_url, data=body, headers=headers)
    with urllib.request.urlopen(req, timeout=TIMEOUT) as resp:
        ctype = resp.headers.get("Content-Type", "") or ""
        if "json" not in ctype.lower():
            _log("warn", "bus returned non-JSON content-type '{}'".format(ctype))
            raise ValueError("bus returned non-JSON content-type: {}".format(ctype or "unknown"))
        raw = resp.read()
        try:
            parsed = json.loads(raw)
        except Exception as e:
            _log("warn", "bus response JSON parse failed: {}".format(e))
            raise
        if not isinstance(parsed, dict):
            _log("warn", "bus response is not a JSON object")
            raise ValueError("bus response is not a JSON object")
        return parsed


def _post_event(envelope):
    return _post_event_to(envelope, BUS_URL, TOKEN)


def _read_text(path):
    try:
        with open(path, "r", encoding="utf-8") as fh:
            return fh.read()
    except OSError:
        return ""


def _extract_installed_hook_env(settings_text):
    if not settings_text.strip():
        return {}
    try:
        data = json.loads(settings_text)
    except Exception:
        return {}
    hooks = data.get("hooks") if isinstance(data, dict) else None
    if not isinstance(hooks, dict):
        return {}

    for entries in hooks.values():
        if not isinstance(entries, list):
            continue
        for entry in entries:
            commands = entry.get("hooks") if isinstance(entry, dict) else None
            if not isinstance(commands, list):
                continue
            for command in commands:
                text = command.get("command") if isinstance(command, dict) else ""
                if not isinstance(text, str) or "claude-code-gate" not in text:
                    continue
                found = {}
                try:
                    parts = shlex.split(text)
                except ValueError:
                    parts = text.split()
                for part in parts:
                    if "=" not in part:
                        continue
                    key, value = part.split("=", 1)
                    if key in {
                        "HOOKBUS_URL",
                        "HOOKBUS_TOKEN",
                        "HOOKBUS_SOURCE",
                        "HOOKBUS_FAIL_MODE",
                        "HOOKBUS_INSTANCE_ID",
                    }:
                        found[key] = value
                return found
    return {}


def _settings_status(settings_text):
    if not settings_text.strip():
        return False, "missing or empty settings.json"
    try:
        data = json.loads(settings_text)
    except Exception as exc:
        return False, "invalid JSON: {}".format(exc)
    hooks = data.get("hooks") if isinstance(data, dict) else None
    if not isinstance(hooks, dict):
        return False, "missing hooks root"
    required = ("UserPromptSubmit", "PreToolUse", "PostToolUse", "Stop")
    missing = []
    for event in required:
        entries = hooks.get(event)
        ok = False
        if isinstance(entries, list):
            for entry in entries:
                commands = entry.get("hooks") if isinstance(entry, dict) else None
                if not isinstance(commands, list):
                    continue
                if any(
                    isinstance(command, dict)
                    and "claude-code-gate" in str(command.get("command", ""))
                    for command in commands
                ):
                    ok = True
                    break
        if not ok:
            missing.append(event)
    if missing:
        return False, "missing HookBus handlers for: {}".format(", ".join(missing))
    return True, "HookBus handlers installed"


def _doctor():
    print("Claude Code HookBus doctor")
    print("This validates the installed gate, Claude Code settings, and HookBus event path.")
    print("It cannot prove that an already-running Claude Code session has reloaded settings; restart Claude Code after install.")
    print()

    ok = True
    gate_path = os.path.realpath(sys.argv[0])
    if os.path.exists(gate_path):
        print("ok claude-code-gate - {}".format(gate_path))
    else:
        print("fail claude-code-gate - missing {}".format(gate_path))
        ok = False

    settings_path = os.environ.get("CLAUDE_SETTINGS", os.path.expanduser("~/.claude/settings.json"))
    settings_text = _read_text(settings_path)
    settings_ok, detail = _settings_status(settings_text)
    print("{} claude settings - {}: {}".format("ok" if settings_ok else "fail", settings_path, detail))
    ok = ok and settings_ok

    installed_env = _extract_installed_hook_env(settings_text)
    bus_url = installed_env.get("HOOKBUS_URL", BUS_URL)
    token = installed_env.get("HOOKBUS_TOKEN", TOKEN)
    print("ok HOOKBUS_URL - {}".format(bus_url))
    if not token:
        print("warn HOOKBUS_TOKEN - empty; authenticated buses will reject events")

    probe = {
        "event_id": str(uuid.uuid4()),
        "event_type": "UserPromptSubmit",
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "source": installed_env.get("HOOKBUS_SOURCE", SOURCE),
        "session_id": "claude-code-doctor",
        "tool_name": "",
        "tool_input": {"prompt": "doctor probe"},
        "metadata": {
            "publisher": "hookbus-claude-code-publisher",
            "publisher_version": __version__,
            "doctor": True,
        },
    }
    try:
        result = _post_event_to(probe, bus_url, token)
        decision = result.get("decision", "allow") if isinstance(result, dict) else "allow"
        print("ok hookbus event - accepted with decision={}".format(decision))
    except Exception as exc:
        print("fail hookbus event - {}".format(exc))
        ok = False

    print()
    print("Doctor passed." if ok else "Doctor failed.")
    return 0 if ok else 1


def _read_transcript_with_backoff(path, attempts=(0.1, 0.5, 1.0)):
    """Read a Claude Code transcript JSONL with poll/backoff.

    Stop hook fires before the transcript is fsynced on busy sessions, so a
    naive read can miss the final assistant turn. Try up to len(attempts)
    times, sleeping between, and accept the read once mtime stops changing.
    Returns the parsed list of JSONL messages or None on failure.
    """
    import time
    if not path or not os.path.isfile(path):
        return None
    last_mtime = -1.0
    for delay in attempts:
        time.sleep(delay)
        try:
            mtime = os.path.getmtime(path)
        except OSError:
            return None
        if mtime == last_mtime:
            break
        last_mtime = mtime
    try:
        with open(path, "r", encoding="utf-8") as fh:
            messages = []
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    messages.append(json.loads(line))
                except Exception:
                    continue
            return messages
    except OSError as e:
        _log("warn", "transcript read failed ({}): {}".format(path, e))
        return None


def _extract_reasoning_from_transcript(messages):
    """Walk transcript JSONL backwards, return concatenated thinking blocks
    from the most recent assistant message.

    Claude Code transcript format: each line is {type, message: {role, content}}
    where content is a list of blocks. Thinking blocks have {type: "thinking",
    thinking: "..."}. We scan from the end so we capture only the turn that
    triggered Stop, not earlier turns in the session.
    """
    if not messages:
        return ""
    for entry in reversed(messages):
        msg = entry.get("message") if isinstance(entry, dict) else None
        if not isinstance(msg, dict):
            continue
        if msg.get("role") != "assistant":
            continue
        content = msg.get("content")
        if not isinstance(content, list):
            continue
        thinking_parts = []
        for block in content:
            if not isinstance(block, dict):
                continue
            if block.get("type") == "thinking":
                t = block.get("thinking")
                if isinstance(t, str):
                    thinking_parts.append(t)
        return "\n".join(thinking_parts)
    return ""


def _extract_last_assistant_response_from_transcript(messages):
    """Return the most recent assistant text from the transcript.

    Stop hook input should include last_assistant_message, but transcript
    fallback gives older Claude Code versions and partial hook payloads a
    second chance.
    """
    if not messages:
        return ""
    for entry in reversed(messages):
        msg = entry.get("message") if isinstance(entry, dict) else None
        if not isinstance(msg, dict) or msg.get("role") != "assistant":
            continue
        content = msg.get("content")
        if isinstance(content, str):
            return content
        if not isinstance(content, list):
            continue
        parts = []
        for block in content:
            if not isinstance(block, dict):
                continue
            if block.get("type") == "text" and isinstance(block.get("text"), str):
                parts.append(block["text"])
        if parts:
            return "\n".join(parts)
    return ""


def _stop_trace_metadata(hook_input):
    """Best-effort: extract assistant response and readable thinking blocks
    from Stop hook input/transcript.

    Claude Code documents `last_assistant_message` on Stop input. Readable
    `thinking` blocks are not guaranteed; current Claude builds may emit signed
    or empty thinking markers. We report response reliably when present and
    reasoning only when exposed as text.
    """
    metadata = {}
    last_message = hook_input.get("last_assistant_message")
    if isinstance(last_message, str) and last_message:
        metadata["response_text"] = last_message
        metadata["response_chars"] = len(last_message)

    transcript_path = hook_input.get("transcript_path") or hook_input.get("transcriptPath")
    messages = _read_transcript_with_backoff(transcript_path) if transcript_path else None

    if not metadata.get("response_text"):
        response = _extract_last_assistant_response_from_transcript(messages)
        if response:
            metadata["response_text"] = response
            metadata["response_chars"] = len(response)

    reasoning = _extract_reasoning_from_transcript(messages)
    if reasoning:
        metadata["reasoning_content"] = reasoning[:16000]
        metadata["reasoning_chars"] = len(reasoning)
        metadata["reasoning_truncated"] = len(reasoning) > 16000

    if transcript_path:
        metadata["transcript_path"] = transcript_path
    return metadata


def _emit_stop_trace(hook_input):
    """Best-effort: post a ModelResponse event on Stop with assistant output
    and any readable reasoning exposed by Claude Code.

    Fire-and-forget. Never raises. Never blocks the main Stop flow.
    """
    try:
        trace = _stop_trace_metadata(hook_input)
        if not trace.get("response_text") and not trace.get("reasoning_content"):
            return
        envelope = {
            "event_id": str(uuid.uuid4()),
            "event_type": "ModelResponse",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "source": SOURCE,
            "session_id": hook_input.get("session_id", ""),
            "tool_name": "llm.response",
            "tool_input": {},
            "metadata": {
                "publisher": "hookbus-claude-code-publisher",
                "publisher_version": __version__,
                "provider": "anthropic",
                **_identity_metadata(),
                **trace,
            },
        }
        try:
            _post_event(envelope)
        except Exception as e:
            _log("warn", "ModelResponse post failed: {}".format(e))
    except Exception as e:
        _log("warn", "stop trace extraction failed: {}".format(e))


def main():
    hook_input = _read_hook_input()
    if hook_input is None:
        sys.exit(0)

    hook = hook_input.get("hook_event_name", "")
    tool_name = hook_input.get("tool_name", hook_input.get("toolName", ""))
    tool_input = hook_input.get("tool_input", hook_input.get("toolInput", {}))

    if not hook:
        hook = "PreToolUse" if tool_name else "UserPromptSubmit"

    if hook == "UserPromptSubmit" and not tool_input:
        tool_input = {"prompt": hook_input.get("prompt", hook_input.get("content", ""))}

    envelope = {
        "event_id": str(uuid.uuid4()),
        "event_type": hook,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "source": SOURCE,
        "session_id": hook_input.get("session_id", ""),
        "tool_name": tool_name,
        "tool_input": tool_input,
        "metadata": {
            "publisher": "hookbus-claude-code-publisher",
            "publisher_version": __version__,
            **_identity_metadata(),
        },
    }

    # Stop hook: best-effort emit of ModelResponse alongside the gate call so
    # subscribers can capture the final assistant output and readable reasoning
    # where Claude Code exposes it. Fire-and-forget, never blocks.
    if hook == "Stop":
        _emit_stop_trace(hook_input)

    try:
        result = _post_event(envelope)
    except Exception as e:
        _log("warn", "bus unreachable ({}), failing {}".format(e, FAIL_MODE))
        if FAIL_MODE == "closed":
            # Fail-closed: surface as deny on blockable events, silent allow elsewhere.
            reason = "HookBus unreachable: {}".format(e)
            if hook == "PreToolUse":
                print(json.dumps({
                    "hookSpecificOutput": {
                        "hookEventName": "PreToolUse",
                        "permissionDecision": "deny",
                        "permissionDecisionReason": reason,
                    }
                }))
                sys.exit(2)
            if hook == "Stop":
                print(json.dumps({"decision": "block", "reason": reason}))
                sys.exit(2)
        # Fail-open: Claude Code is never bricked by a missing bus.
        if hook == "UserPromptSubmit":
            sys.exit(0)
        print(json.dumps({}))
        sys.exit(0)

    if result is None:
        # Envelope serialisation failed. Fail per FAIL_MODE.
        if hook == "UserPromptSubmit":
            sys.exit(0)
        print(json.dumps({}))
        sys.exit(0)

    decision = result.get("decision", "allow")
    reason = result.get("reason", "") or ""

    # UserPromptSubmit: legacy plain-text stdout is the injection path.
    if hook == "UserPromptSubmit":
        if reason.startswith("[cre] "):
            reason = reason[6:]
        sys.stdout.write(reason)
        sys.stdout.flush()
        sys.exit(0)

    # Deny, event-type specific output
    if decision == "deny":
        if hook == "PreToolUse":
            print(json.dumps({
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "deny",
                    "permissionDecisionReason": reason,
                }
            }))
        elif hook == "Stop":
            # Stop schema forbids hookSpecificOutput; use top-level decision.
            print(json.dumps({"decision": "block", "reason": reason}))
        else:
            # PostToolUse and others: no structured deny; surface as systemMessage.
            print(json.dumps({"systemMessage": reason}))
        sys.exit(2)

    # Ask is PreToolUse-only
    if decision == "ask":
        if hook == "PreToolUse":
            print(json.dumps({
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "ask",
                    "additionalContext": reason,
                }
            }))
        else:
            print(json.dumps({}))
        sys.exit(0)

    if decision != "allow":
        _log("warn", "unknown verdict decision '{}' for {}, defaulting to allow".format(decision, hook))

    # Allow, event-type specific output
    if hook in ("PreToolUse", "PostToolUse"):
        if reason:
            print(json.dumps({
                "hookSpecificOutput": {
                    "hookEventName": hook,
                    "additionalContext": reason,
                }
            }))
        else:
            print(json.dumps({}))
    elif hook == "Stop":
        # Stop schema forbids hookSpecificOutput. Silent allow.
        print(json.dumps({}))
    else:
        print(json.dumps({}))
    sys.exit(0)


if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] == "--doctor":
        sys.exit(_doctor())
    main()
