#!/usr/bin/env python3
"""HookBus thin client for Claude Code hooks.

Reads the hook JSON Claude Code writes to stdin, posts it to the HookBus HTTP
endpoint, and translates the bus verdict back into Claude Code's per-event
output schema.

Supported hook events:
    UserPromptSubmit  , plain text injection (additionalContext)
    PreToolUse        , hookSpecificOutput.permissionDecision + reason
    PostToolUse       , hookSpecificOutput.additionalContext (optional)
    Stop              , top-level decision / reason (schema forbids hookSpecificOutput)

Environment:
    HOOKBUS_URL       default http://localhost:18800/event
    HOOKBUS_TOKEN     bearer token, optional
    HOOKBUS_SOURCE    label for dashboard, default claude-code
    HOOKBUS_TIMEOUT   HTTP timeout in seconds, default 30
    HOOKBUS_FAIL_MODE 'open' (default) allows on bus unreachable; 'closed' denies
    HOOKBUS_DEBUG     set to '1' to emit diagnostic logs on stderr

Exit codes:
    0 allow (Claude Code continues)
    2 deny  (Claude Code blocks the action)

On bus unreachable the gate fails open by default (HOOKBUS_FAIL_MODE=open) so
Claude Code is never bricked by a missing bus. Set HOOKBUS_FAIL_MODE=closed for
regulated environments that require governance to be enforced even when the bus
is down.

Licence: MIT. Copyright 2026 Agentic Thinking Limited.
"""
import json
import os
import sys
import uuid
import urllib.request
from datetime import datetime, timezone
from urllib.parse import urlparse


__version__ = "0.2.1"

BUS_URL = os.environ.get("HOOKBUS_URL", "http://localhost:18800/event")
TOKEN = os.environ.get("HOOKBUS_TOKEN", "").strip()
SOURCE = os.environ.get("HOOKBUS_SOURCE", "claude-code")
TIMEOUT = int(os.environ.get("HOOKBUS_TIMEOUT", "30"))
_FAIL_MODE_RAW = os.environ.get("HOOKBUS_FAIL_MODE", "open").strip().lower()
FAIL_MODE = "closed" if _FAIL_MODE_RAW == "closed" else "open"
DEBUG = os.environ.get("HOOKBUS_DEBUG", "") == "1"


def _log(level, msg):
    if not DEBUG and level == "info":
        return
    sys.stderr.write("[hookbus-claude-code] {}: {}\n".format(level, msg))


# Startup validation: warn on obviously-broken config but do not crash.
try:
    _parsed_url = urlparse(BUS_URL)
    if _parsed_url.scheme not in ("http", "https"):
        _log("error", "HOOKBUS_URL has unsupported scheme '{}', only http/https allowed".format(_parsed_url.scheme))
    elif not _parsed_url.netloc:
        _log("error", "HOOKBUS_URL missing host: {}".format(BUS_URL))
except Exception as _e:
    _log("error", "HOOKBUS_URL is not a valid URL ({}): {}".format(BUS_URL, _e))
if not TOKEN:
    _log("warn", "HOOKBUS_TOKEN is empty; authenticated buses will reject requests")
_log("info", "started v{} (source={}, fail_mode={}, bus={})".format(__version__, SOURCE, FAIL_MODE, BUS_URL))


def _read_hook_input():
    raw = sys.stdin.read()
    if not raw.strip():
        return None
    try:
        return json.loads(raw)
    except Exception as e:
        _log("warn", "hook stdin is not valid JSON: {}".format(e))
        return None


def _post_event(envelope):
    # Envelope serialisation guard: circular refs in tool_input should not crash the gate.
    try:
        body = json.dumps(envelope).encode()
    except (TypeError, ValueError) as e:
        _log("warn", "envelope serialisation failed: {}".format(e))
        return None

    headers = {"Content-Type": "application/json"}
    if TOKEN:
        headers["Authorization"] = "Bearer " + TOKEN
    req = urllib.request.Request(BUS_URL, data=body, headers=headers)
    with urllib.request.urlopen(req, timeout=TIMEOUT) as resp:
        ctype = resp.headers.get("Content-Type", "") or ""
        if "json" not in ctype.lower():
            _log("warn", "bus returned non-JSON content-type '{}'".format(ctype))
            raise ValueError("bus returned non-JSON content-type: {}".format(ctype or "unknown"))
        raw = resp.read()
        try:
            parsed = json.loads(raw)
        except Exception as e:
            _log("warn", "bus response JSON parse failed: {}".format(e))
            raise
        if not isinstance(parsed, dict):
            _log("warn", "bus response is not a JSON object")
            raise ValueError("bus response is not a JSON object")
        return parsed


def main():
    hook_input = _read_hook_input()
    if hook_input is None:
        sys.exit(0)

    hook = hook_input.get("hook_event_name", "")
    tool_name = hook_input.get("tool_name", hook_input.get("toolName", ""))
    tool_input = hook_input.get("tool_input", hook_input.get("toolInput", {}))

    if not hook:
        hook = "PreToolUse" if tool_name else "UserPromptSubmit"

    if hook == "UserPromptSubmit" and not tool_input:
        tool_input = {"prompt": hook_input.get("prompt", hook_input.get("content", ""))}

    envelope = {
        "event_id": str(uuid.uuid4()),
        "event_type": hook,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "source": SOURCE,
        "session_id": hook_input.get("session_id", ""),
        "tool_name": tool_name,
        "tool_input": tool_input,
        "metadata": {
            "publisher": "hookbus-claude-code-publisher",
            "publisher_version": __version__,
        },
    }

    try:
        result = _post_event(envelope)
    except Exception as e:
        _log("warn", "bus unreachable ({}), failing {}".format(e, FAIL_MODE))
        if FAIL_MODE == "closed":
            # Fail-closed: surface as deny on blockable events, silent allow elsewhere.
            reason = "HookBus unreachable: {}".format(e)
            if hook == "PreToolUse":
                print(json.dumps({
                    "hookSpecificOutput": {
                        "hookEventName": "PreToolUse",
                        "permissionDecision": "deny",
                        "permissionDecisionReason": reason,
                    }
                }))
                sys.exit(2)
            if hook == "Stop":
                print(json.dumps({"decision": "block", "reason": reason}))
                sys.exit(2)
        # Fail-open: Claude Code is never bricked by a missing bus.
        if hook == "UserPromptSubmit":
            sys.exit(0)
        print(json.dumps({}))
        sys.exit(0)

    if result is None:
        # Envelope serialisation failed. Fail per FAIL_MODE.
        if hook == "UserPromptSubmit":
            sys.exit(0)
        print(json.dumps({}))
        sys.exit(0)

    decision = result.get("decision", "allow")
    reason = result.get("reason", "") or ""

    # UserPromptSubmit: legacy plain-text stdout is the injection path.
    if hook == "UserPromptSubmit":
        if reason.startswith("[cre] "):
            reason = reason[6:]
        sys.stdout.write(reason)
        sys.stdout.flush()
        sys.exit(0)

    # Deny, event-type specific output
    if decision == "deny":
        if hook == "PreToolUse":
            print(json.dumps({
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "deny",
                    "permissionDecisionReason": reason,
                }
            }))
        elif hook == "Stop":
            # Stop schema forbids hookSpecificOutput; use top-level decision.
            print(json.dumps({"decision": "block", "reason": reason}))
        else:
            # PostToolUse and others: no structured deny; surface as systemMessage.
            print(json.dumps({"systemMessage": reason}))
        sys.exit(2)

    # Ask is PreToolUse-only
    if decision == "ask":
        if hook == "PreToolUse":
            print(json.dumps({
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "ask",
                    "additionalContext": reason,
                }
            }))
        else:
            print(json.dumps({}))
        sys.exit(0)

    if decision != "allow":
        _log("warn", "unknown verdict decision '{}' for {}, defaulting to allow".format(decision, hook))

    # Allow, event-type specific output
    if hook in ("PreToolUse", "PostToolUse"):
        if reason:
            print(json.dumps({
                "hookSpecificOutput": {
                    "hookEventName": hook,
                    "additionalContext": reason,
                }
            }))
        else:
            print(json.dumps({}))
    elif hook == "Stop":
        # Stop schema forbids hookSpecificOutput. Silent allow.
        print(json.dumps({}))
    else:
        print(json.dumps({}))
    sys.exit(0)


if __name__ == "__main__":
    main()
